# Local app
APP_ENV=local
PORT=8000
RUNS_DIR=/app/runs

# Shared-secret auth for POST /triage.
TRIAGE_API_KEY=change-me-local

# LLM backend: mock, anthropic, or foundry. Use mock for credential-free local evals.
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-6

# First-party Anthropic API.
ANTHROPIC_API_KEY=

# Azure AI Foundry Claude endpoint. Used only when LLM_PROVIDER=foundry.
AZURE_FOUNDRY_RESOURCE=
AZURE_FOUNDRY_BASE_URL=
AZURE_FOUNDRY_API_KEY=

# Tracing. Leave empty for local runs without Logfire cloud export.
LOGFIRE_TOKEN=
LOGFIRE_ENVIRONMENT=local

# Eval runner defaults.
EVAL_API_URL=http://localhost:8000
